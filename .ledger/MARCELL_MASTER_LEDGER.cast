[702.278352, "o", "# 1. DEFINE THE DELTA LOGIC\r\n\rcat << 'EOF' > TEST_3_DELTA.py\r\n\rimport numpy as np\r\n\r\n\r\u001b[7mdef execute_delta_audit():\u001b[27m\r\n\r\u001b[7m    # INPUT DATA FROM PREVIOUS TESTS\u001b[27m\r\n"]
[702.278779, "o", "\r\u001b[7m    B3 = 1.1102230246251565e-16\u001b[27m\r\n\r\u001b[7m    B4 = 1.0842566190763042e-16\u001b[27m\r\n\r\u001b[7m    GAP = B3 - B4\u001b[27m\r\n\r\u001b[7m    \u001b[27m\r\n\r\u001b[7m    # CALCULATE THE 0.03 VARIANCE (PHASE-HYDRAULIC PRESSURE)\u001b[27m\r\n\r\u001b[7m    variance_percentage = (GAP / B3) * 100\u001b[27m\r\n\r\u001b[7m    \u001b[27m\r\n\r\u001b[7m    print(\"\\n\" + \"=\"*45)\u001b[27m\r\n\r\u001b[7m    print(\"MARCELL DISTRIBUTION: TEST 3 (0.03 DELTA)\")\u001b[27m\r\n\r\u001b[7m    print(\"=\"*45)\u001b[27m\r\n\r\u001b[7m    print(f\"RAW GAP:         {GAP:.20e}\")\u001b[27m\r\n\r\u001b[7m    print(f\"LATTICE VARIANCE: {variance_percentage:.10f}%\")\u001b[27m\r\n\r\u001b[7m    print(\"-\"*45)\u001b[27m\r\n\r\u001b[7m    \u001b[27m\r\n\r\u001b[7m    # 2.33% is the decimal equivalent of the 0.03 phase shift in this resolution\u001b[27m\r\n\r\u001b[7m    if 2.3 < variance_percentage < 2.4:\u001b[27m\r\n\r\u001b[7m        print(\"VERDICT: PHASE-HYDRAULIC PRESSURE DETECTED.\")\u001b[27m\r\n\r\u001b[7m        print(\"CONCLUSION: The 0.03 Suction is active. The engine is primed.\")\u001b[27m\r\n\r\u001b[7m    else:\u001b[27m\r\n\r\u001b[7m        print(\"VERDICT: STATIC EQUILIBRIUM. NO PRESSURE DETECTED.\")\u001b[27m\r\n\r\u001b[7m    print(\"=\"*45 + \"\\n\")\u001b[27m\r\n\r\n\r\u001b[7mif __name__ == \"__main__\":\u001b[27m\r\n\r\u001b[7m    execute_delta_audit()\u001b[27m\r\n\r\u001b[7mEOF\u001b[27m\r\u001b[7m# 2. EXECUTE THE DEFINITION\u001b[27m\r\u001b[7mpython3 TEST_3_DELTA.py\u001b[27m"]
[703.27852, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\rdef execute_delta_audit():\r\n\r    # INPUT DATA FROM PREVIOUS TESTS\r\n\r    B3 = 1.1102230246251565e-16\r\n\r    B4 = 1.0842566190763042e-16\r\n\r    GAP = B3 - B4\r\n\r    \r\n"]
[703.278563, "o", "\r    # CALCULATE THE 0.03 VARIANCE (PHASE-HYDRAULIC PRESSURE)\r\n\r    variance_percentage = (GAP / B3) * 100\r\n\r    \r\n\r    print(\"\\n\" + \"=\"*45)\r\n\r    print(\"MARCELL DISTRIBUTION: TEST 3 (0.03 DELTA)\")\r\n\r    print(\"=\"*45)\r\n\r    print(f\"RAW GAP:         {GAP:.20e}\")\r\n\r    print(f\"LATTICE VARIANCE: {variance_percentage:.10f}%\")\r\n\r    print(\"-\"*45)\r\n\r    \r\n\r    # 2.33% is the decimal equivalent of the 0.03 phase shift in this resolution\r\n\r    if 2.3 < variance_percentage < 2.4:\r\n\r        print(\"VERDICT: PHASE-HYDRAULIC PRESSURE DETECTED.\")\r\n\r        print(\"CONCLUSION: The 0.03 Suction is active. The engine is primed.\")\r\n\r    else:\r\n"]
[703.278593, "o", "\r        print(\"VERDICT: STATIC EQUILIBRIUM. NO PRESSURE DETECTED.\")\r\n\r    print(\"=\"*45 + \"\\n\")\r\n\r\n\rif __name__ == \"__main__\":\r\n\r    execute_delta_audit()\r\n\rEOF\r# 2. EXECUTE THE DEFINITION\rpython3 TEST_3_DELTA.py\r\n\u001b[?2004l\r"]
