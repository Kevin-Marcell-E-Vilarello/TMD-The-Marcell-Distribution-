[1431.977315, "o", "# 1. COMPILE THE MASS SWEEP ARTIFACT\r\n\rcat << 'EOF' > QX2_MASS_SWEEP.py\r\n\r\u001b[7mimport numpy as np\u001b[27m\r\n\r\n\r\u001b[7mdef run_mass_sweep():\u001b[27m\r\n\r\u001b[7m    print(\"\\n\" + \"=\"*45)\u001b[27m\r\n\r\u001b[7m    print(\"MARCELL ARTIFACT 2: QX2 MASS SWEEP\")\u001b[27m\r\n\r\u001b[7m    print(\"=\"*45)\u001b[27m\r\n\r\u001b[7m    \u001b[27m\r\n\r\u001b[7m    # Sweep from 0 to Pi/2 (The Marcell Phase Quadrant)\u001b[27m\r\n\r\u001b[7m    phases = np.linspace(0, np.pi/2, 10)\u001b[27m\r\n\r\u001b[7m    \u001b[27m\r\n\r\u001b[7m    print(f\"{'PHASE (rad)':<15} | {'LATTICE RATIO':<15}\")\u001b[27m\r\n\r\u001b[7m    print(\"-\" * 35)\u001b[27m\r\n\r\u001b[7m    \u001b[27m\r\n\r\u001b[7m    for p in phases:\u001b[27m\r\n\r\u001b[7m        # Ratio derived from the Cosine of the Phase (The U-Valley)\u001b[27m\r\n\r\u001b[7m        ratio = np.cos(p)\u001b[27m\r\n\r\u001b[7m        print(f\"{p:<15.4f} | {ratio:<15.10f}\")\u001b[27m\r\n\r\u001b[7m    \u001b[27m\r\n\r\u001b[7m    print(\"-\" * 45)\u001b[27m\r\n\r\u001b[7m    # The Singularity check\u001b[27m\r\n\r\u001b[7m    if np.isclose(np.cos(0.0), 1.0):\u001b[27m\r\n"]
[1431.977649, "o", "\r\u001b[7m        print(\"VERDICT: SINGULARITY DETECTED AT 0.0.\")\u001b[27m\r\n\r\u001b[7m        print(\"CONCLUSION: The 'U-Valley' is centered. Mass is deterministic.\")\u001b[27m\r\n\r\u001b[7m    print(\"=\"*45 + \"\\n\")\u001b[27m\r\n\r\n\r\u001b[7mif __name__ == \"__main__\":\u001b[27m\r\n\r\u001b[7m    run_mass_sweep()\u001b[27m\r\n\r\u001b[7mEOF\u001b[27m\r\n\r\n\r\u001b[7m# 2. RUN THE ARTIFACT\u001b[27m\r\u001b[7mpython3 QX2_MASS_SWEEP.py\u001b[27m"]
[1433.108631, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\rimport numpy as np\r\n\r\n\rdef run_mass_sweep():\r\n\r    print(\"\\n\" + \"=\"*45)\r\n\r    print(\"MARCELL ARTIFACT 2: QX2 MASS SWEEP\")\r\n\r    print(\"=\"*45)\r\n\r    \r\n\r    # Sweep from 0 to Pi/2 (The Marcell Phase Quadrant)\r\n\r    phases = np.linspace(0, np.pi/2, 10)\r\n\r    \r\n\r    print(f\"{'PHASE (rad)':<15} | {'LATTICE RATIO':<15}\")\r\n\r    print(\"-\" * 35)\r\n\r    \r\n\r    for p in phases:\r\n\r        # Ratio derived from the Cosine of the Phase (The U-Valley)\r\n\r        ratio = np.cos(p)\r\n"]
[1433.108806, "o", "\r        print(f\"{p:<15.4f} | {ratio:<15.10f}\")\r\n\r    \r\n\r    print(\"-\" * 45)\r\n\r    # The Singularity check\r\n\r    if np.isclose(np.cos(0.0), 1.0):\r\n\r        print(\"VERDICT: SINGULARITY DETECTED AT 0.0.\")\r\n\r        print(\"CONCLUSION: The 'U-Valley' is centered. Mass is deterministic.\")\r\n\r    print(\"=\"*45 + \"\\n\")\r\n\r\n\rif __name__ == \"__main__\":\r\n\r    run_mass_sweep()\r\n\rEOF\r\n\r\n\r# 2. RUN THE ARTIFACT\rpython3 QX2_MASS_SWEEP.py\r\n\u001b[?2004l\r"]
