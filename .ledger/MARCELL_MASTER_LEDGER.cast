INGERPRINT)\\u001b[27m\\r\\n\\r\\u001b[7mgit log -1 --format=\\\"%H\\\"\\u001b[27m\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[9027.554669, \"o\", \"\\u001b[A\\u001b[A\\u001b[A\\u001b[A\\r\\u001b[C\\u001b[C\\u001b[C\\u001b[C\\u001b[C\\u001b[C\\u001b[C# 1. ENTER THE TWIN'S CHAMBER\\r\\n\\rcd ~/Desktop/MARCELL_LATTICE_FINAL\\r\\n\\r\\n\\r# 2. ASK FOR THE UNIQUE IDENTIFIER (THE FINGERPRINT)\\r\\n\\rgit log -1 --format=\\\"%H\\\"\\r\\n\\u001b[?2004l\\r\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[9027.560244, \"o\", \"\\u001b[?1h\\u001b=\\r475b3ca5f9f3068b79c65418854066284ef43653\\u001b[m\\r\\n\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[9027.561452, \"o\", \"\\r\\u001b[K\\u001b[?1l\\u001b>\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[9027.562105, \"o\", \"\\u001b[?2004h\\r\\r\\n\\u001b[38;5;172m┌──╼ \\u001b[38;5;172m.~QVANTVM+ \\u001b[38;5;172m[UNiOS.Q0~] \\u001b[38;5;172m~/Desktop/MARCELL_LATTICE_FINAL\\r\\r\\n\\u001b[38;5;172m└──╼ \\u001b[38;5;172m$ \\u001b[0m\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[9067.247525, \"o\", \"\\u001b[7m# CHECK FOR DIFFERENTIAL DRIFT\\u001b[27m\\r\\n\\r\\u001b[7mgit diff\\u001b[27m\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[9069.54199, \"o\", \"\\u001b[A\\b# CHECK FOR DIFFERENTIAL DRIFT\\r\\n\\rgit diff\\r\\n\\u001b[?2004l\\r\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[9069.545803, \"o\", \"\\u001b[?1h\\u001b=\\r\"]\u001b[m\u001b[m\r\n\u001b[1m~\u001b[0m\r\n\u001b[1m~\u001b[0m\r\n\u001b[1m~\u001b[0m\r\n\u001b[1m~\u001b[0m\r\n\u001b[1m~\u001b[0m\r\n\u001b[1m~\u001b[0m\r\n\u001b[1m~\u001b[0m\r\n\u001b[7m(END)\u001b[27m\u001b[K"]
