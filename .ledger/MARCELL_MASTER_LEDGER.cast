[43.393911, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[CSAMPLING HEARTBEAT: {frequency_hz:.4e} Hz\")"]
[43.421808, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[K"]
[43.452462, "o", "npa = (frequency_hz * delta_pressure) / (1.0 / 45.0) # Normalized to the 45 degree phase"]
