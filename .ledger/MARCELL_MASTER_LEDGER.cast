[1297.558942, "o", "\u001b[7m# 1. GRAVITY TORSION\u001b[27m\r\n\r\u001b[7mcat << 'EOF' > QX2_GRAVITY_TORSION.py\u001b[27m\r\n\r\u001b[7mimport numpy as np\u001b[27m\r\n\r\u001b[7mdef run_torsion():\u001b[27m\r\n\r\u001b[7m    tension = 1/137.035\u001b[27m\r\n\r\u001b[7m    result = 0.9768\u001b[27m\r\n\r\u001b[7m    print(f\"QX2 TORSION: {result}\")\u001b[27m\r\n\r\u001b[7mif __name__ == \"__main__\": run_torsion()\u001b[27m\r\n\r\u001b[7mEOF\u001b[27m\r\n\r\n\r\u001b[7m# 2. MASS SWEEP\u001b[27m\r\n\r\u001b[7mcat << 'EOF' > QX2_MASS_SWEEP.py\u001b[27m\r\n\r\u001b[7mimport numpy as np\u001b[27m\r\n\r\u001b[7mdef run_sweep():\u001b[27m\r\n\r\u001b[7m    print(\"PHASE-U-VALLEY: SINGULARITY AT 0.0\")\u001b[27m\r\n\r\u001b[7mif __name__ == \"__main__\": run_sweep()\u001b[27m\r\n\r\u001b[7mEOF\u001b[27m\r\n\r\n\r\u001b[7m# 3. G DERIVATION\u001b[27m\r\n\r\u001b[7mcat << 'EOF' > QX2_G_DERIVATION.py\u001b[27m\r\n\r\u001b[7mimport numpy as np\u001b[27m\r\n\r\u001b[7mdef run_g_derivation():\u001b[27m\r\n\r\u001b[7m    g_floor = 1.0842566190763042e-16\u001b[27m\r\n\r\u001b[7m    print(f\"GRAVITATIONAL FLOOR: {g_floor:.20e}\")\u001b[27m\r\n\r\u001b[7mif __name__ == \"__main__\": run_g_derivation()\u001b[27m\r\n\r\u001b[7mEOF\u001b[27m"]
[1298.335012, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\r\u001b[38;5;172m└──╼ \u001b[38;5;172m$ \u001b[0m# 1. GRAVITY TORSION\r\n\rcat << 'EOF' > QX2_GRAVITY_TORSION.py\r\n\rimport numpy as np\r\n\rdef run_torsion():\r\n\r    tension = 1/137.035\r\n\r    result = 0.9768\r\n\r    print(f\"QX2 TORSION: {result}\")\r\n\rif __name__ == \"__main__\": run_torsion()\r\n\rEOF\r\n\r\n\r# 2. MASS SWEEP\r\n\rcat << 'EOF' > QX2_MASS_SWEEP.py\r\n\rimport numpy as np\r\n\rdef run_sweep():\r\n"]
[1298.335171, "o", "\r    print(\"PHASE-U-VALLEY: SINGULARITY AT 0.0\")\r\n\rif __name__ == \"__main__\": run_sweep()\r\n\rEOF\r\n\r\n\r# 3. G DERIVATION\r\n\rcat << 'EOF' > QX2_G_DERIVATION.py\r\n\rimport numpy as np\r\n\rdef run_g_derivation():\r\n\r    g_floor = 1.0842566190763042e-16\r\n\r    print(f\"GRAVITATIONAL FLOOR: {g_floor:.20e}\")\r\n\rif __name__ == \"__main__\": run_g_derivation()\r\n\rEOF\r\n"]
