[9249.68966, "o", "\r\n\u001b[32m+\u001b[m\u001b[32m[8880.333104, \"o\", \"\\r\\u001b[7mgit commit -m \\\"A9_ON: ADDING MASS WITHOUT DISTURBING THE 1.000 CORE\\\"\\u001b[27m\\r\\n\\r\\n\\r\\u001b[7m# 4. PUSH\\u001b[27m\\r\\n\\r\\u001b[7mgit push origin main\\u001b[27m\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[8886.907343, \"o\", \"\\u001b[A\\u001b[A\\u001b[A\\u001b[A\\u001b[A\\u001b[A\\u001b[A\\u001b[A\\u001b[A\\u001b[A\\r\\u001b[C\\u001b[C\\u001b[C\\u001b[C\\u001b[C\\u001b[C\\u001b[C# 1. ONLY ADD THE NEW STUFF\\r\\n\\rgit add A9_on/New_Folder/\\r\\n\\r\\n\\r# 2. DO NOT USE \\\"git add .\\\" IF YOU ARE WORRIED\\r\\n\\r# Specifying the exact file/folder ensures the 1.000 f\u001b[m \b\u001b[32m\u001b[m\u001b[32miles are untouched.\\r\\n\\r\\n\\r# 3. COMMIT THE ADDITION\\r\\n\\rgit commit -m \\\"A9_ON: ADDING MASS WITHOUT DISTURBING THE 1.000 CORE\\\"\\r\\n\\r\\n\\r# 4. PUSH\\r\\n\\rgit push origin main\\r\\n\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[8886.907394, \"o\", \"\\u001b[?2004l\\r\"]\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m[8886.909436, \"o\", \"warning: could not open directory 'A9_on/New_Folder/': No such file or directory\\r\\nfatal"]
